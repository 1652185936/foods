ORDIN_ENVIRONMENT=development
ORDIN_DEVELOPMENT_OTP_CODE=123456

# Forwarded headers are accepted only from these immediate proxy peers.
ORDIN_FORWARDED_ALLOW_IPS=127.0.0.1

# Local MinIO and the Redis database reserved for Celery. Production uses private
# S3 credentials, HTTPS endpoints, and a dedicated durable Redis broker.
ORDIN_CELERY_BROKER_URL=redis://127.0.0.1:6379/1
ORDIN_S3_ENDPOINT_URL=http://127.0.0.1:9000
ORDIN_S3_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000
ORDIN_S3_BUCKET=ordin-private
ORDIN_S3_ACCESS_KEY_ID=minioadmin
ORDIN_S3_SECRET_ACCESS_KEY=minioadmin

# Synthetic recognition is intentionally restricted to development/test.
ORDIN_RECOGNITION_PROVIDER_BACKEND=development
ORDIN_RECOGNITION_SOURCE_RETENTION_SECONDS=86400

# Account exports fail explicitly instead of truncating. Deleted-account objects
# are retried by the bounded maintenance queue.
ORDIN_ACCOUNT_EXPORT_MAX_RECORDS=10000
ORDIN_ACCOUNT_CLEANUP_BATCH_SIZE=100
ORDIN_ACCOUNT_CLEANUP_CLAIM_LEASE_SECONDS=300

# Staging/production provider example (HTTPS and a 32+ character token required):
# ORDIN_RECOGNITION_PROVIDER_BACKEND=http
# ORDIN_RECOGNITION_PROVIDER_URL=https://private-recognition.example/v1/analyze
# ORDIN_RECOGNITION_PROVIDER_TOKEN=replace-with-a-secret-manager-value
# ORDIN_RECOGNITION_PROVIDER_NAME=vendor-model-version

# Production/staging require webhook mode, HTTPS, and a token of at least 32 characters.
# ORDIN_OTP_SENDER_BACKEND=webhook
# ORDIN_OTP_WEBHOOK_URL=https://private-sms-relay.example/v1/otp
# ORDIN_OTP_WEBHOOK_TOKEN=replace-with-a-secret-manager-value
