ORDIN_COMPOSE_PROJECT_NAME=ordin-production
ORDIN_IMAGE_REPOSITORY=ghcr.io/REPLACE_WITH_OWNER/ordin-server
ORDIN_IMAGE_SHA256=REPLACE_WITH_64_HEX_DIGEST
ORDIN_EDGE_NETWORK=REPLACE_WITH_EXISTING_REVERSE_PROXY_NETWORK
ORDIN_PUBLIC_API_ORIGIN=https://api.example.invalid
ORDIN_DATABASE_URL=postgresql+psycopg://ordin_app:REPLACE_WITH_DATABASE_SECRET@db.example.invalid:5432/ordin?sslmode=verify-full
ORDIN_MIGRATION_DATABASE_URL=postgresql+psycopg://ordin_migrator:REPLACE_WITH_MIGRATION_SECRET@db.example.invalid:5432/ordin?sslmode=verify-full
ORDIN_REDIS_URL=rediss://:REPLACE_WITH_REDIS_SECRET@cache.example.invalid:6379/0
ORDIN_CELERY_BROKER_URL=rediss://:REPLACE_WITH_BROKER_SECRET@broker.example.invalid:6379/0?ssl_cert_reqs=required
ORDIN_S3_ENDPOINT_URL=https://s3.example.invalid
ORDIN_S3_PUBLIC_ENDPOINT_URL=https://uploads.example.invalid
ORDIN_S3_REGION=REPLACE_WITH_REGION
ORDIN_S3_BUCKET=REPLACE_WITH_PRIVATE_BUCKET
ORDIN_S3_ACCESS_KEY_ID=REPLACE_WITH_OBJECT_ACCESS_KEY
ORDIN_S3_SECRET_ACCESS_KEY=REPLACE_WITH_OBJECT_SECRET_KEY
ORDIN_S3_FORCE_PATH_STYLE=false
ORDIN_JWT_ISSUER=https://api.example.invalid
ORDIN_JWT_AUDIENCE=ordin-client
ORDIN_JWT_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_IDENTITY_HMAC_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_OTP_HMAC_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_TOKEN_HMAC_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_IDEMPOTENCY_HMAC_SECRET=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_OTP_WEBHOOK_URL=https://otp-relay.example.invalid/v1/send
ORDIN_OTP_WEBHOOK_TOKEN=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_RECOGNITION_PROVIDER_URL=https://recognition.example.invalid/v1/analyze
ORDIN_RECOGNITION_PROVIDER_TOKEN=REPLACE_WITH_SECRET_MANAGER_VALUE
ORDIN_RECOGNITION_PROVIDER_NAME=REPLACE_WITH_PROVIDER_IDENTIFIER
ORDIN_RECOGNITION_SOURCE_RETENTION_SECONDS=86400
ORDIN_FORWARDED_ALLOW_IPS=REPLACE_WITH_PROXY_IP_OR_CIDR
ORDIN_API_REPLICAS=2
ORDIN_WORKER_REPLICAS=2
ORDIN_WORKER_CONCURRENCY=2
